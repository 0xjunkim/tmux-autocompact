#!/bin/bash
# tmux-autocompact-clear: clear tmux pane history immediately.

find_tmux_server_pid() {
  pgrep -x 'tmux: server' 2>/dev/null && return 0
  pgrep -f 'tmux.*server' 2>/dev/null && return 0
  ps -ax -o pid=,tty=,command= 2>/dev/null | awk '$2 == "??" && $3 == "tmux" { print $1; exit }'
}

COUNT_ONLY=0
if [ "${1:-}" = "--count" ]; then
  COUNT_ONLY=1
elif [ -n "${1:-}" ]; then
  echo "tmux-autocompact-clear: unsupported argument: $1" >&2
  exit 1
fi

count=0
while IFS= read -r pane; do
  tmux clear-history -t "$pane"
  count=$((count + 1))
done < <(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)

pid=$(find_tmux_server_pid)
rss_kb=0
if [ -n "$pid" ]; then
  rss_kb=$(ps -o rss= -p "$pid" 2>/dev/null | tr -d ' ')
fi

if [ "$COUNT_ONLY" -eq 1 ]; then
  printf '%s\n' "$count"
  exit 0
fi

tmux display-message "tmux-autocompact: cleared ${count} panes; server RSS now $((rss_kb / 1024))MB" 2>/dev/null || true
